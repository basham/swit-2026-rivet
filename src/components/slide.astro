---
import { getSlideId } from "../util.js";

const id = getSlideId();
---

<swit-slide id={id}>
	<slot />
</swit-slide>

<style is:global>
	swit-slide {
		align-items: center;
		background-color: var(--rvt-color-theme-background);
		border-block-end: var(--rvt-size-8) solid var(--rvt-color-theme-ui);
		display: block;
		font-size: 6vmin;
		justify-content: center;
		padding: 1em;
		height: 100vh;
		width: 100vw;

		> * {
			font-size: inherit;
			line-height: 1.25;
			margin-block-end: 0;
		}

		b {
			color: var(--rvt-color-theme-text-accent);
		}

		h1 {
			font-weight: var(--rvt-font-weight-bold);
			font-size: 2em;
		}

		h2 {
			font-weight: var(--rvt-font-weight-bold);
			font-size: 1.5em;
		}

		mark {
			background-color: var(--rvt-color-theme-background-accent-strong);
			color: var(--rvt-color-theme-text-strong);
		}

		strong {
			font-stretch: var(--rvt-font-width-expanded);
		}

		table {
			margin-block-start: 1em;

			th {
				font-size: inherit;
				line-height: inherit;
			}
		}
	}
</style>
