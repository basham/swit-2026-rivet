---
import { getSlideId } from "../util.js";

const id = getSlideId();
---

<swit-slide id={id}>
	<slot />
</swit-slide>

<style is:global>
	html {
		background-color: var(--rvt-color-theme-ui);
	}

	swit-slide {
		align-items: center;
		background-color: var(--rvt-color-theme-background);
		display: block;
		font-size: 6vmin;
		justify-content: center;
		margin-block-end: var(--rvt-size-4);
		padding: 1em;
		height: 100vmin;
		width: 100vw;

		&:has(h1) {
			background-color: var(--rvt-color-theme-ui);
			text-align: center;
		}

		&:has(h2) {
			background-color: var(--rvt-color-theme-background-strong);
		}

		> * {
			font-size: inherit;
			line-height: 1.25;
			margin: 0;

			&:not(:first-child) {
				margin-block-start: 0.5em;
			}
		}

		b {
			color: var(--rvt-color-theme-text-accent);
		}

		code {
			font-family: var(--rvt-font-family-mono);
			font-size: 0.75em;
		}

		h1,
		h2,
		h3 {
			font-weight: var(--rvt-font-weight-bold);
		}

		h1 {
			font-size: 2em;
		}

		h2 {
			font-size: 1.5em;
		}

		h3 {
			font-size: 1.25em;
		}

		mark {
			background-color: var(--rvt-color-theme-background-accent-strong);
			color: var(--rvt-color-theme-text-strong);
		}

		pre {
			tab-size: 4;
			white-space: pre-line;
		}

		li {
			margin-block-start: 0.5em;
		}

		ol,
		ul {
			padding-inline-start: 2ch;
		}

		small {
			font-size: 0.75em;
		}

		table {
			margin-block-start: 1em;

			th {
				font-size: inherit;
				font-stretch: inherit;
				line-height: inherit;
			}
		}
	}
</style>
